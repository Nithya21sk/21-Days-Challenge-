class BankAccount:
    def __init__(self, owner, balance):
        self.owner = owner
        self.balance = balance

    def deposit(self, amount):
        self.balance += amount
        print("Amount Deposited:", amount)

    def show_balance(self):
        print("Current Balance:", self.balance)

acc1 = BankAccount("Karpaga", 1000)

acc1.deposit(500)
acc1.show_balance()
